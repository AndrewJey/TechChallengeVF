# Copy this file to .env and fill in real values. .env is gitignored.

# --- PostgreSQL (alternative to docs/db_credentials.txt) ---
# If these are set they take precedence over docs/db_credentials.txt.
PGDATABASE=tienda
PGUSER=postgres
PGPASSWORD=your_password
PGHOST=localhost
PGPORT=5432

# --- Static site / file scraping ---
# Port must match how you serve web_sample (python -m http.server 8000).
STATIC_BASE_URL=http://localhost:8000/

# --- Optional Flask API (json_api_server.py) ---
API_PORT=5001

# --- Bonus: LLM selector generation ---
# Azure OpenAI key from the VoiceFlip challenge PDF (rotate before sharing publicly).
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://voiceflip-openai.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# Only needed if you use the public-OpenAI variant (Connections/pruebaLLM.py).
OPENAI_API_KEY=
